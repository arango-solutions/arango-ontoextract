# Loaded automatically by `next dev`. `make dev` exports BACKEND_PROXY_URL to match BACKEND_PORT.
BACKEND_PROXY_URL=http://127.0.0.1:8010

# Local dev bypasses the scaffold login: middleware lets every route through and
# the /login page auto-redirects into the app (see src/middleware.ts and
# src/app/login/page.tsx). Only loaded by `next dev` — production `next build`
# reads .env.production, so auth stays enforced in real deployments.
NEXT_PUBLIC_DEV_MODE=true
