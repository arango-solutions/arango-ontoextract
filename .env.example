# =============================================================================
# Arango-OntoExtract (AOE) — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -- Deployment Mode -----------------------------------------------------------
# Controls which ArangoDB connection profile is active and which features
# are available (GAE, SmartGraphs, SatelliteCollections, etc.).
#
# Options:
#   local_docker           — Single ArangoDB server in Docker (no GAE, no SSL)
#   self_managed_platform  — Remote ArangoDB cluster (GAE enabled, SSL, Enterprise)
#   managed_platform       — ArangoDB Managed Platform / AMP (requires ArangoDB 4.0+)
#
TEST_DEPLOYMENT_MODE=local_docker

# -- ArangoDB (local_docker) ---------------------------------------------------
ARANGO_HOST=http://localhost:8530
ARANGO_DB=ontology_generator
ARANGO_USER=root
ARANGO_PASSWORD=changeme
ARANGO_NO_AUTH=false

# -- ArangoDB (self_managed_platform) ------------------------------------------
# Uncomment when TEST_DEPLOYMENT_MODE=self_managed_platform:
# ARANGO_ENDPOINT=https://your-cluster-host:8529
# ARANGO_DB=ontology_generator
# ARANGO_USER=root
# ARANGO_PASSWORD=your-cluster-password
# ARANGO_VERIFY_SSL=true
# ARANGO_TIMEOUT=30

# -- ArangoDB (managed_platform / AMP) ----------------------------------------
# Uncomment when TEST_DEPLOYMENT_MODE=managed_platform (requires ArangoDB 4.0+):
# GAE_DEPLOYMENT_MODE=amp
# ARANGO_ENDPOINT=https://your-deployment.arangodb.cloud:8529
# ARANGO_DB=your-db
# ARANGO_USER=root
# ARANGO_PASSWORD=your-db-password
# ARANGO_GRAPH_API_KEY_ID=your-api-key-id
# ARANGO_GRAPH_API_KEY_SECRET=your-api-key-secret
# ARANGO_VERIFY_SSL=true
# ARANGO_TIMEOUT=30

# -- Redis (task queue) --------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -- LLM Providers -------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Primary model for ontology extraction
LLM_EXTRACTION_MODEL=claude-sonnet-4-20250514
# Embedding model for chunks and entity resolution
EMBEDDING_MODEL=text-embedding-3-small

# -- Application ---------------------------------------------------------------
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-this-to-a-random-string

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# -- Extraction Defaults -------------------------------------------------------
EXTRACTION_PASSES=3
EXTRACTION_CONSISTENCY_THRESHOLD=2
EXTRACTION_CONFIDENCE_MIN=0.6

# -- Entity Resolution Defaults ------------------------------------------------
ER_VECTOR_SIMILARITY_THRESHOLD=0.85
ER_VECTOR_WEIGHT=0.6
ER_TOPO_WEIGHT=0.4

# -- Admin / Development -------------------------------------------------------
# Set to true to enable /api/v1/admin/reset endpoints (dev/demo only)
ALLOW_SYSTEM_RESET=false
