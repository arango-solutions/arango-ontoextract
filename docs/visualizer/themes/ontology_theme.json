{
  "name": "AOE Ontology Theme",
  "graphId": "domain_ontology",
  "isDefault": true,
  "createdAt": null,
  "updatedAt": null,
  "nodeConfigMap": {
    "ontology_classes": {
      "background": { "color": "#3B82F6", "iconName": "fa6-solid:shapes" },
      "labelAttribute": "label",
      "hoverInfoAttributes": ["label", "uri", "description", "ontology_id", "confidence", "status", "tier"],
      "rules": [
        {
          "name": "SKOS Concept",
          "condition": "rdf_type == 'skos:Concept'",
          "background": { "color": "#10B981", "iconName": "fa6-solid:tag" }
        },
        {
          "name": "OWL Restriction",
          "condition": "rdf_type == 'owl:Restriction'",
          "background": { "color": "#F97316", "iconName": "fa6-solid:lock" }
        },
        {
          "name": "Tier 2 Local",
          "condition": "tier == 'local'",
          "background": { "color": "#60A5FA", "iconName": "fa6-solid:shapes" }
        },
        {
          "name": "Staging Pending",
          "condition": "status == 'pending'",
          "background": { "color": "#93C5FD", "iconName": "fa6-solid:clock" }
        },
        {
          "name": "Approved",
          "condition": "status == 'approved'",
          "background": { "color": "#2563EB", "iconName": "fa6-solid:circle-check" }
        },
        {
          "name": "Rejected",
          "condition": "status == 'rejected'",
          "background": { "color": "#EF4444", "iconName": "fa6-solid:circle-xmark" }
        }
      ]
    },
    "ontology_properties": {
      "background": { "color": "#8B5CF6", "iconName": "fa6-solid:arrow-right-arrow-left" },
      "labelAttribute": "label",
      "hoverInfoAttributes": ["label", "uri", "description", "ontology_id", "property_type", "confidence"],
      "rules": [
        {
          "name": "DatatypeProperty",
          "condition": "property_type == 'DatatypeProperty'",
          "background": { "color": "#14B8A6", "iconName": "fa6-solid:font" }
        },
        {
          "name": "Staging Pending",
          "condition": "status == 'pending'",
          "background": { "color": "#C4B5FD", "iconName": "fa6-solid:clock" }
        },
        {
          "name": "Approved",
          "condition": "status == 'approved'",
          "background": { "color": "#7C3AED", "iconName": "fa6-solid:circle-check" }
        },
        {
          "name": "Rejected",
          "condition": "status == 'rejected'",
          "background": { "color": "#EF4444", "iconName": "fa6-solid:circle-xmark" }
        }
      ]
    },
    "ontology_constraints": {
      "background": { "color": "#F97316", "iconName": "fa6-solid:lock" },
      "labelAttribute": "constraint_type",
      "hoverInfoAttributes": ["constraint_type", "uri", "description", "ontology_id"],
      "rules": []
    },
    "ontology_registry": {
      "background": { "color": "#EAB308", "iconName": "fa6-solid:book" },
      "labelAttribute": "label",
      "hoverInfoAttributes": ["label", "uri", "description", "version", "source"],
      "rules": []
    },
    "documents": {
      "background": { "color": "#6B7280", "iconName": "fa6-solid:file-lines" },
      "labelAttribute": "filename",
      "hoverInfoAttributes": ["filename", "status", "content_type", "uploaded_at"],
      "rules": []
    },
    "chunks": {
      "background": { "color": "#9CA3AF", "iconName": "fa6-solid:puzzle-piece" },
      "labelAttribute": "_key",
      "hoverInfoAttributes": ["_key", "doc_id", "chunk_index", "section_heading"],
      "rules": []
    },
    "extraction_runs": {
      "background": { "color": "#EC4899", "iconName": "fa6-solid:gears" },
      "labelAttribute": "_key",
      "hoverInfoAttributes": ["_key", "doc_id", "status", "model", "started_at"],
      "rules": [
        {
          "name": "Completed",
          "condition": "status == 'completed'",
          "background": { "color": "#10B981", "iconName": "fa6-solid:circle-check" }
        },
        {
          "name": "Failed",
          "condition": "status == 'failed'",
          "background": { "color": "#EF4444", "iconName": "fa6-solid:circle-xmark" }
        }
      ]
    }
  },
  "edgeConfigMap": {
    "subclass_of": {
      "lineStyle": { "color": "#1E40AF", "thickness": 1.5 },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "triangle" },
      "hoverInfoAttributes": ["created", "expired", "ontology_id"],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    },
    "equivalent_class": {
      "lineStyle": { "color": "#F97316", "thickness": 1.2, "lineType": "dashed" },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "none" },
      "hoverInfoAttributes": ["created", "expired", "ontology_id"],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    },
    "has_property": {
      "lineStyle": { "color": "#6B7280", "thickness": 1.0 },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "triangle" },
      "hoverInfoAttributes": ["created", "expired", "ontology_id"],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    },
    "extends_domain": {
      "lineStyle": { "color": "#10B981", "thickness": 1.5, "lineType": "dashed" },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "diamond" },
      "hoverInfoAttributes": ["created", "expired", "ontology_id"],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    },
    "extracted_from": {
      "lineStyle": { "color": "#9CA3AF", "thickness": 0.8, "lineType": "dotted" },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "triangle" },
      "hoverInfoAttributes": ["extraction_run_id"],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    },
    "related_to": {
      "lineStyle": { "color": "#6366F1", "thickness": 1.0 },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "triangle" },
      "hoverInfoAttributes": ["created", "expired", "ontology_id", "relationship_type"],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    },
    "merge_candidate": {
      "lineStyle": { "color": "#F59E0B", "thickness": 1.0, "lineType": "dashed" },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "none" },
      "hoverInfoAttributes": ["similarity_score", "match_reason"],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    },
    "imports": {
      "lineStyle": { "color": "#EAB308", "thickness": 1.2 },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "diamond" },
      "hoverInfoAttributes": ["ontology_id"],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    },
    "has_chunk": {
      "lineStyle": { "color": "#9CA3AF", "thickness": 0.8 },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "triangle" },
      "hoverInfoAttributes": [],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    },
    "produced_by": {
      "lineStyle": { "color": "#EAB308", "thickness": 1.0, "lineType": "dashed" },
      "arrowStyle": { "sourceArrowShape": "none", "targetArrowShape": "triangle" },
      "hoverInfoAttributes": [],
      "rules": [],
      "labelStyle": { "color": "#1d2531" }
    }
  }
}
